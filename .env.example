# Environment Variables Configuration
# Copy this file to .env and fill in your values

# Telegram Bot Token (required for Telegram integration)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Replay pending Telegram updates that arrived while bot was offline (default: 1)
TELEGRAM_REPLAY_PENDING_UPDATES_ON_STARTUP=1
# Optional startup replay limits (batch size <= 100)
# TELEGRAM_PENDING_UPDATES_BATCH_SIZE=100
# TELEGRAM_PENDING_UPDATES_MAX_BATCHES=5

# NVIDIA API Key (optional - has fallback in code)
NVIDIA_API_KEY=your_nvidia_api_key_here

# Model ID for the AI model (optional - has fallback in code)
MODEL_ID=moonshotai/kimi-k2-instruct-0905

# Automatic memory capture cadence (target roughly 1 memory per 10-20 messages)
AUTO_MEMORY_ENABLED=1
AUTO_MEMORY_MIN_MESSAGES_PER_MEMORY=10
AUTO_MEMORY_TARGET_MESSAGES_PER_MEMORY=15
AUTO_MEMORY_MAX_MESSAGES_PER_MEMORY=20
# Near-duplicate threshold for auto memory capture dedupe (0.70-0.99)
AUTO_MEMORY_DEDUPE_THRESHOLD=0.90

# Dream-mode memory consolidation (learns off-peak hours from usage history)
MEMORY_DREAM_ENABLED=1
# How many days to inspect when learning off-peak windows (default: 21)
MEMORY_DREAM_LOOKBACK_DAYS=21
# Minimum distinct active days before enabling learned off-peak scheduling (default: 14)
MEMORY_DREAM_MIN_DAYS=14
# Width of learned off-peak window in hours (default: 6)
MEMORY_DREAM_OFFPEAK_WINDOW_HOURS=6
# Minimum hours between dream cycles (default: 24)
MEMORY_DREAM_MIN_INTERVAL_HOURS=24
# Candidate selection for consolidation
MEMORY_DREAM_MIN_CANDIDATES=4
MEMORY_DREAM_CANDIDATE_LIMIT=24
MEMORY_DREAM_MIN_AGE_HOURS=24

# Sendblue iMessage Integration (optional)
SENDBLUE_API_KEY=your_sendblue_api_key_here
SENDBLUE_API_SECRET=your_sendblue_api_secret_here
SENDBLUE_NUMBER=your_sendblue_number_here
# SENDBLUE_WEBHOOK_PORT=8080 # Set this to enable webhooks instead of polling
SENDBLUE_POLL_INTERVAL=10
# Replay recent inbound messages after reconnect (default: enabled)
SENDBLUE_STARTUP_REPLAY_ENABLED=1
# Seconds of startup lookback to detect messages received while offline (default: 21600)
SENDBLUE_STARTUP_LOOKBACK_SECONDS=21600
# Prefer replaying unread messages only when read state is available (default: 1)
SENDBLUE_STARTUP_UNREAD_ONLY=1
# If Sendblue omits read state, still replay recent inbound messages (default: 1)
SENDBLUE_STARTUP_REPLAY_UNKNOWN_READ_STATE=1
# Optional processed-handle dedupe TTL for polling/webhook paths (default: 60)
# SENDBLUE_DEDUP_TTL_SECONDS=60
# Enable iMessage voice memo transcription (default: 1)
SENDBLUE_VOICE_MEMO_TRANSCRIPTION_ENABLED=1
# NVIDIA Riva gRPC endpoint and function-id for NVIDIA parakeet-ctc-0_6b-asr
SENDBLUE_VOICE_MEMO_GRPC_SERVER=grpc.nvcf.nvidia.com:443
SENDBLUE_VOICE_MEMO_FUNCTION_ID=d8dd4e9b-fbf5-4fb0-9dba-8cf436c8d965
# Optional model override (usually routed by function-id)
# SENDBLUE_VOICE_MEMO_MODEL=
# Optional language hint (default: en-US for parakeet-ctc-0_6b-asr)
SENDBLUE_VOICE_MEMO_LANGUAGE=en-US
# Optional ffmpeg binary/path used to convert iMessage .m4a/.caf voice memos when needed
# SENDBLUE_VOICE_MEMO_FFMPEG_BIN=ffmpeg
# Max attachment size in bytes for transcription (default 25MB)
SENDBLUE_VOICE_MEMO_MAX_BYTES=26214400
